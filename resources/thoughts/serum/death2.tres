[resource]
script = ExtResource("1_hl88b")
title = "Jeśli to czytasz..."
content = "Nazywam się Alan Sleep i pracuje jako chirurg dla QuickBeauty od paru miesięcy. Wiedziałem, że coś z nimi  nie gra, ale dzisaj wybuchł kompletny haos. Shelle są wszędzie lepiej uważać na kroki. Chyba nie wróce juz do domu. Jeśli to czytasz to powiedz mojej żonie, że ją kocham. "
metadata/_custom_type_script = "uid://db4xf6hpks04h"
